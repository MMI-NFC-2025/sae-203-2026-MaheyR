---
const { artiste, imageUrl, dateTexte } = Astro.props;
---

<a href={`/artistes/${artiste.id}`} class="block">
  <article class="overflow-hidden rounded-3xl bg-white shadow-md">
    <div class="relative">
      <img src={imageUrl} alt={artiste.nom} class="h-56 w-full object-cover" />

      <span class="absolute right-3 top-3 rounded-full bg-cyan-400 px-4 py-1 text-sm text-white shadow">
        {artiste.genre}
      </span>
    </div>

    <div class="p-5">
      <h2 class="text-2xl font-bold">{artiste.nom}</h2>
      <p class="mt-2 text-base text-gray-500">{dateTexte}</p>
    </div>
  </article>
</a>
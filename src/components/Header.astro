---
const { subtitle = "" } = Astro.props;
---

<header>
  <div class="header-container">
    <img src="/Group 3.png" alt="Mascotte" class="mascotte" />
    
    <div class="header-content">
      <h1>SAVOU'FEST</h1>
      {subtitle && <h2>{subtitle}</h2>}
    </div>
    
    <nav class="nav-desktop">
      <a href="/">Accueil</a>
      <a href="/programme">Programme</a>
      <a href="/artistes">Artistes</a>
      <a href="/scenes">Scènes</a>
      <a href="/infos-pratiques">Infos</a>
      <a href="/contact">Contact</a>
    </nav>
    
    <img src="/Art girl.png" alt="Art girl" class="art-girl" />
    
    <button class="menu-btn" id="menu-btn" aria-label="Ouvrir le menu">☰</button>
  </div>

  <div class="menu-mobile" id="menu-mobile">
    <div class="menu-mobile-header">
      <button class="menu-close" id="menu-close" aria-label="Fermer le menu">✕</button>
    </div>
    <nav class="menu-mobile-nav">
      <a href="/">Accueil</a>
      <a href="/artistes">Artistes</a>
      <a href="/programme">Programme</a>
      <a href="/scenes">Scènes</a>
      <a href="/infos-pratiques">Infos Pratiques</a>
      <a href="/contact">Contact</a>
    </nav>
  </div>
</header>

<style>
  header {
    background: linear-gradient(135deg, #ff9a3c 0%, #ff6b3c 100%);
    padding: 1.5rem;
    color: white;
    position: relative;
    overflow: hidden;
  }

  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 2rem;
    position: relative;
  }

  .mascotte {
    width: 80px;
    height: auto;
    z-index: 2;
  }

  .header-content {
    text-align: center;
    z-index: 2;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: 2px;
    margin: 0;
  }

  h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 0.5rem;
  }

  .nav-desktop {
    display: none;
  }

  .art-girl {
    position: absolute;
    right: 0;
    bottom: 0;
    height: 120px;
    width: auto;
    z-index: 1;
  }

  .menu-btn {
    background: none;
    border: none;
    color: white;
    font-size: 2rem;
    cursor: pointer;
    padding: 0.5rem;
    z-index: 2;
    display: none;
  }

  .menu-mobile {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, #ff9a3c 0%, #ff6b3c 100%);
    z-index: 9999;
    display: flex;
    flex-direction: column;
    padding: 2rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .menu-mobile.active {
    opacity: 1;
    visibility: visible;
  }

  .menu-mobile-header {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 2rem;
  }

  .menu-close {
    background: none;
    border: none;
    color: white;
    font-size: 2.5rem;
    cursor: pointer;
    padding: 0.5rem;
    line-height: 1;
  }

  .menu-mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
    padding-top: 3rem;
  }

  .menu-mobile-nav a {
    color: white;
    text-decoration: none;
    font-size: 2rem;
    font-weight: 700;
    transition: opacity 0.2s ease;
  }

  .menu-mobile-nav a:active {
    opacity: 0.7;
  }

  @media (min-width: 1024px) {
    .header-container {
      grid-template-columns: auto auto 1fr auto;
      gap: 2rem;
    }

    .nav-desktop {
      display: flex;
      gap: 1.5rem;
      justify-self: end;
      margin-right: 8rem;
      z-index: 2;
    }

    .nav-desktop a {
      color: white;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.95rem;
    }

    .menu-mobile {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .header-container {
      grid-template-columns: auto 1fr auto;
      gap: 1rem;
    }

    .mascotte {
      width: 60px;
    }

    h1 {
      font-size: 1.8rem;
    }

    h2 {
      font-size: 1.2rem;
    }

    .art-girl {
      height: 100px;
    }

    .menu-btn {
      display: block;
    }
  }

  @media (max-width: 480px) {
    .mascotte {
      width: 50px;
    }

    h1 {
      font-size: 1.5rem;
    }

    h2 {
      font-size: 1rem;
    }

    .art-girl {
      height: 80px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const menuBtn = document.getElementById('menu-btn');
    const menuClose = document.getElementById('menu-close');
    const menuMobile = document.getElementById('menu-mobile');
    const menuLinks = document.querySelectorAll('.menu-mobile-nav a');
    menuBtn?.addEventListener('click', () => {
      menuMobile?.classList.add('active');
      document.body.style.overflow = 'hidden'; 
    });

    menuClose?.addEventListener('click', () => {
      menuMobile?.classList.remove('active');
      document.body.style.overflow = ''; 
    });
    menuLinks.forEach(link => {
      link.addEventListener('click', () => {
        menuMobile?.classList.remove('active');
        document.body.style.overflow = '';
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menuMobile?.classList.contains('active')) {
        menuMobile.classList.remove('active');
        document.body.style.overflow = '';
      }
    });
  });
</script>
---
// @ts-nocheck
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PBImage from "../../components/PBImage.astro";
import { getAllArtistesSortedByDate } from "../../../backend/backend.mjs";

const genre = Astro.url.searchParams.get("genre");

let artistes = await getAllArtistesSortedByDate();

if (genre && genre !== "Tous") {
  artistes = artistes.filter((item) => item.artiste?.genre === genre);
}

const genres = ["Tous", "Electro", "Pop", "Hip-Hop", "Rock"];

function buildGenreUrl(selectedGenre) {
  if (!selectedGenre || selectedGenre === "Tous") {
    return "/artistes";
  }

  return `/artistes?genre=${encodeURIComponent(selectedGenre)}`;
}

function formatDate(dateString) {
  if (!dateString) return "";
  const date = new Date(dateString);

  return date.toLocaleDateString("fr-FR", {
    weekday: "long",
    day: "2-digit",
    month: "short",
  });
}
---

<Layout title="Artistes">
  <Header subtitle="Artistes" />

  <main>
    <section class="filters-section">
      <h2>Filtrer par genre</h2>

      <div class="filters">
        {
          genres.map((item) => {
            const isActive = (!genre && item === "Tous") || genre === item;

            return (
              <a
                href={buildGenreUrl(item)}
                class={`filter-btn ${isActive ? "active" : ""}`}
              >
                {item}
              </a>
            );
          })
        }
      </div>
    </section>

    <section class="artistes-grid">
      {
        artistes.length > 0 ? (
          artistes.map((item) => {
            const artiste = item.artiste;
            const dateTexte = formatDate(item.date);
            const heureTexte = item.heure_debut ? ` - ${item.heure_debut}` : "";

            return (
              <article class="artiste-card">
                <a href={`/artistes/${artiste.id}`}>
                  <div class="artiste-image">
                    <PBImage
                      record={artiste}
                      filename={artiste.photo}
                      alt={artiste.nom}
                    />
                    <span class="genre-badge">{artiste.genre}</span>
                  </div>

                  <div class="artiste-info">
                    <h3>{artiste.nom}</h3>
                    <p class="artiste-date">
                      {dateTexte}
                      {heureTexte}
                    </p>
                  </div>
                </a>
              </article>
            );
          })
        ) : (
          <p class="no-results">
            Aucun artiste ne correspond au filtre sélectionné.
          </p>
        )
      }
    </section>
  </main>

  <Footer />
</Layout>

<style>
  main {
    background: var(--color-bg-secondary);
    padding: var(--spacing-xl) var(--spacing-md) var(--spacing-3xl);
  }

  .filters-section {
    max-width: var(--max-width-lg);
    margin: 0 auto var(--spacing-2xl);
  }

  .filters-section h2 {
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-extrabold);
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-md);
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .filter-btn {
    padding: 0.75rem var(--spacing-md);
    border-radius: var(--radius-full);
    border: 2px solid var(--color-border-light);
    background: var(--color-bg-primary);
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    box-shadow: var(--shadow-xs);
    transition: all var(--transition-base);
  }

  .filter-btn.active {
    background: var(--color-cyan);
    border-color: var(--color-cyan);
    color: white;
  }

  .artistes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--spacing-lg);
    max-width: var(--max-width-3xl);
    margin: 0 auto;
  }

  .artiste-card {
    background: var(--color-bg-primary);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: transform var(--transition-base);
  }

  .artiste-card a {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .artiste-image {
    position: relative;
    height: 250px;
    overflow: hidden;
  }

  .artiste-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .genre-badge {
    position: absolute;
    top: var(--spacing-sm);
    right: var(--spacing-sm);
    background: var(--color-cyan);
    color: white;
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-full);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
  }

  .artiste-info {
    padding: var(--spacing-md);
  }

  .artiste-info h3 {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-extrabold);
    color: var(--color-text-primary);
    margin: 0 0 var(--spacing-xs) 0;
  }

  .artiste-date {
    color: var(--color-text-tertiary);
    font-size: var(--font-size-sm);
    margin: 0;
  }

  .no-results {
    grid-column: 1 / -1;
    text-align: center;
    padding: var(--spacing-2xl);
    background: var(--color-bg-primary);
    border-radius: var(--radius-lg);
    color: var(--color-text-tertiary);
    font-size: var(--font-size-md);
  }

  @media (min-width: 1024px) {
    .artistes-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .artistes-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-md);
    }
  }
</style>